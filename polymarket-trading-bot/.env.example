# Polymarket API配置
# 获取API密钥: https://docs.polymarket.com/#authentication
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here

# 以太坊钱包配置
# ⚠️ 警告: 妥善保管私钥,不要泄露或提交到版本控制系统
ETH_PRIVATE_KEY=your_private_key_here
ETH_RPC_URL=https://polygon-rpc.com

# 数据库配置(生产环境使用PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/polymarket

# 交易配置
DRY_RUN=true  # true=模拟交易, false=实际交易
TRADING_ENABLED=false  # 是否启用自动交易

# 告警配置(可选)
# Telegram Bot配置
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Slack Webhook配置
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Sentry错误监控(可选)
SENTRY_DSN=your_sentry_dsn

# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
